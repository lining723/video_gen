APP_HOST=0.0.0.0
APP_PORT=8100
FRONTEND_PORT=3100
APP_API_KEY=dev-secret-key-change-me
OBJECT_STORE_PROVIDER=filesystem
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=ai-video-platform
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
SHOT_DURATION_LIMIT=10
RENDER_WORKERS=4
RETRY_LIMIT=3

# 文本模型配置
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TEXT_MODEL=deepseek
OLLAMA_TIMEOUT=120

TEXT_PROVIDER=deepseek
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_TEXT_MODEL=deepseek-reasoner
DEEPSEEK_TIMEOUT=120

# DashScope 配置（图片和视频生成）
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com
DASHSCOPE_API_KEY=
DASHSCOPE_IMAGE_MODEL=wan2.7-image
DASHSCOPE_VIDEO_MODEL=wan2.7-i2v
DASHSCOPE_IMAGE_SIZE=1024*1024
DASHSCOPE_VIDEO_RESOLUTION=720P
DASHSCOPE_VIDEO_RATIO=16:9
DASHSCOPE_TIMEOUT=300
DASHSCOPE_POLL_INTERVAL=3
DASHSCOPE_POLL_TIMEOUT=360

# 多视频模型配置
# 可用模型列表（逗号分隔）
DASHSCOPE_VIDEO_MODELS=wan2.7-i2v,wan2.7-t2v,wan2.1-i2v
# 默认视频模型ID（格式：{provider}-{model}）
VIDEO_MODEL_DEFAULT=dashscope-wan2.7-i2v

# 火山引擎视频生成配置（可选）
# 在火山方舟平台 https://console.volcengine.com/ark 创建模型接入点
# VOLCENGINE_ENABLED=false
# VOLCENGINE_API_KEY=                        # Bearer Token
# VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com
# VOLCENGINE_VIDEO_MODELS=                   # 模型端点ID，在方舟平台创建后获取
# VOLCENGINE_VIDEO_RESOLUTION=720P           # 480P 或 720P
# VOLCENGINE_VIDEO_MAX_DURATION=10           # 最大10秒
# VOLCENGINE_TIMEOUT=300
# VOLCENGINE_POLL_INTERVAL=3
# VOLCENGINE_POLL_TIMEOUT=360

# Runway 视频生成配置（可选）
# RUNWAY_ENABLED=false
# RUNWAY_API_KEY=
# RUNWAY_BASE_URL=https://api.runwayml.com
# RUNWAY_VIDEO_MODELS=gen3-alpha,gen2

ALLOW_MODEL_FALLBACK=true
